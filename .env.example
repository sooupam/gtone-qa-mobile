## .env.example — template de variáveis necessárias.
## Uso:
##   cp .env.example .env.local
##   editar .env.local com suas credenciais reais (nunca commitar)
##   set -a; source .env.local; set +a
##
## TODAS as variáveis abaixo são OBRIGATÓRIAS. Os scripts falham se faltar.

## Credenciais do user de teste (criar no Supabase local antes)
MAESTRO_TEST_EMAIL=
MAESTRO_TEST_PASSWORD=

## Tenant + Company de teste (criar via SQL no Supabase local)
MAESTRO_TEST_TENANT_SLUG=
MAESTRO_TEST_COMPANY_ID=

## (Opcional) Override do AVD usado nos scripts
AVD_NAME=Pixel_6

## (Opcional) Path do repo principal com Supabase + APK
EFFORTONE_REPO=../effortone
