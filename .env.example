## .env.example — template de variaveis necessarias.
## Uso:
##   cp .env.example .env.local
##   editar .env.local com suas credenciais reais (NUNCA commitar)
##   source scripts/setup-env.sh
##
## TODAS as variaveis primarias sao OBRIGATORIAS. Scripts validam e falham se faltar.

## ── User principal (necessario pra TODOS os flows que requerem login) ──
MAESTRO_TEST_EMAIL=
MAESTRO_TEST_PASSWORD=

## ── Tenant + Company (criar via SQL no Supabase local) ──
MAESTRO_TEST_TENANT_SLUG=
MAESTRO_TEST_COMPANY_ID=

## ── User secundario (apenas pra flow auth/logout_then_login_other_user) ──
MAESTRO_TEST_EMAIL_B=
MAESTRO_TEST_PASSWORD_B=

## ── UUIDs de fixtures (necessario pra deep links e seed conflict) ──
MAESTRO_TEST_WO_ID=
MAESTRO_QR_ASSET_PAYLOAD=

## ── MFA (apenas pra flows auth/mfa_totp_*) ──
MAESTRO_MFA_EMAIL=
MAESTRO_MFA_PASSWORD=
MAESTRO_MFA_SECRET=

## ── (Opcional) Override do AVD ──
AVD_NAME=Pixel_6

## ── (Opcional) Path do repo principal com Supabase + APK ──
EFFORTONE_REPO=../effortone
